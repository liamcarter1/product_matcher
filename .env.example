# Danfoss RAG Chatbot - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# OpenAI Configuration
# =============================================================================

# Your OpenAI API key (required)
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI model for chat completions (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# OpenAI model for embeddings (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# Pinecone Configuration
# =============================================================================

# Your Pinecone API key (required)
PINECONE_API_KEY=pc-your-api-key-here

# Pinecone index name (default: danfoss-products)
PINECONE_INDEX=danfoss-products

# Pinecone environment/region (default: us-east-1)
PINECONE_ENVIRONMENT=us-east-1


# =============================================================================
# JWT Authentication
# =============================================================================

# Secret key for JWT token signing (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiration in hours (default: 24)
JWT_EXPIRATION_HOURS=24


# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (JSON array format)
# Add your distributor website domains here
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","https://your-distributor-site.com"]


# =============================================================================
# Application Settings
# =============================================================================

# Enable debug mode (default: false)
DEBUG=false


# =============================================================================
# Optional: Redis Configuration (for production session storage)
# =============================================================================

# REDIS_URL=redis://localhost:6379/0
