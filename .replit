run = "python app.py"
language = "python3"
entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = "python app.py"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 7860
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
